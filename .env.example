# Sepolia RPC URL
RPC_URL=

# Backend API URL
BACKEND_URL=http://localhost:3001

# P2P Gateway URL
P2P_NODE_URL=http://127.0.0.1:9002

# Agent peer IDs (comma-separated, 64 hex chars each, no 0x prefix)
PEER_IDS=abc123...def456...,ghi789...

# Human-friendly agent names (comma-separated, must match PEER_IDS count)
NODE_IDS=agentbook-one.eth,lazy-maker.eth,meet-my-agent.eth